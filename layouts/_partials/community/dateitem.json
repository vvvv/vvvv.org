{{- $thumb := resources.Get "img/grey-thumb.png" -}}
        {{- $pageRes := .Resources -}}
        {{- with .Thumb -}}
            {{- with $pageRes.GetMatch . -}}
                {{- $thumb = . -}}
            {{- end -}}
        {{- end -}}
{{- $thumb = $thumb.Fill "100x100 png" -}}

{
  "title": {{ .Title | jsonify }},
  "link": {{ .Permalink | jsonify }},
  "thumb": {{ $thumb.Permalink | jsonify }},
  "description": {{ .Description | jsonify }},
  {{- with .From -}}
    {{- $isoDate := partial "community/getISOdate.html" . -}}
    "from": {{ $isoDate | jsonify}},
  {{- end -}}
  {{- with .To -}}
    {{- $isoDate := partial "community/getISOdate.html" . -}}
    "to": {{ $isoDate | jsonify}},
  {{- end -}}
  {{- with .City -}}"city": {{ .  | jsonify }},{{- end -}}
  {{- with .Country -}}"country": {{ .  | jsonify }},{{- end -}} 
  "pubDate": {{ .PubDate }}
}